From 056b732437e1804c59087ab02c81088a1bb40633 Mon Sep 17 00:00:00 2001
From: Chisheng Chen <johnny1001s000602@gmail.com>
Date: Thu, 30 Apr 2026 17:17:33 +0800
Subject: [PATCH 7/9] Add no unwinder option for thumb2

---
 arch/arm/Kconfig             | 2 +-
 arch/arm/Kconfig.debug       | 7 +++++++
 arch/arm/kernel/stacktrace.c | 7 +++++++
 3 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/arch/arm/Kconfig b/arch/arm/Kconfig
index 118f0cd0c..ebfde94df 100644
--- a/arch/arm/Kconfig
+++ b/arch/arm/Kconfig
@@ -1123,7 +1123,7 @@ config THUMB2_KERNEL
 	bool "Compile the kernel in Thumb-2 mode" if !CPU_THUMBONLY
 	depends on (CPU_V7 || CPU_V7M) && !CPU_V6 && !CPU_V6K
 	default y if CPU_THUMBONLY
-	select ARM_UNWIND
+	select ARM_UNWIND if !UNWINDER_NONE
 	help
 	  By enabling this option, the kernel will be compiled in
 	  Thumb-2 mode.
diff --git a/arch/arm/Kconfig.debug b/arch/arm/Kconfig.debug
index 366f162e1..8c40beaa8 100644
--- a/arch/arm/Kconfig.debug
+++ b/arch/arm/Kconfig.debug
@@ -74,6 +74,13 @@ config UNWINDER_ARM
 	  the performance is not affected. Currently, this feature
 	  only works with EABI compilers.
 
+config UNWINDER_NONE
+	bool "No unwinder (smallest image)"
+	help
+	  Disable kernel-side stack unwinding. Panic and warning backtraces
+	  collapse to a single frame, but the EABI unwind tables
+	  (.ARM.exidx/.ARM.extab) are discarded, saving tens of KB.
+
 endchoice
 
 config ARM_UNWIND
diff --git a/arch/arm/kernel/stacktrace.c b/arch/arm/kernel/stacktrace.c
index 620aa82e3..0169b1ae5 100644
--- a/arch/arm/kernel/stacktrace.c
+++ b/arch/arm/kernel/stacktrace.c
@@ -126,6 +126,13 @@ int notrace unwind_frame(struct stackframe *frame)
 }
 #endif
 
+#if !defined(CONFIG_ARM_UNWIND) && !defined(CONFIG_FRAME_POINTER)
+int notrace unwind_frame(struct stackframe *frame)
+{
+	return -EINVAL;
+}
+#endif
+
 void notrace walk_stackframe(struct stackframe *frame,
 		     bool (*fn)(void *, unsigned long), void *data)
 {
-- 
2.43.0

